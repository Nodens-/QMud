#include <winver.h>
#include <winuser.h>

#define IDI_QMUD_APP_ICON 101

IDI_QMUD_APP_ICON ICON "@QMUD_WINDOWS_ICON_DST@"
1 RT_MANIFEST "@QMUD_WINDOWS_MANIFEST_DST@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @QMUD_WINDOWS_VERSION_COMMAS@
 PRODUCTVERSION @QMUD_WINDOWS_VERSION_COMMAS@
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName", "@QMUD_WINDOWS_COMPANY_NAME@\0"
      VALUE "FileDescription", "@QMUD_WINDOWS_FILE_DESCRIPTION@\0"
      VALUE "FileVersion", "@QMUD_WINDOWS_VERSION_DOTS@\0"
      VALUE "InternalName", "@QMUD_WINDOWS_PRODUCT_NAME@\0"
      VALUE "LegalCopyright", "@QMUD_WINDOWS_LEGAL_COPYRIGHT@\0"
      VALUE "OriginalFilename", "@QMUD_WINDOWS_ORIGINAL_FILENAME@\0"
      VALUE "ProductName", "@QMUD_WINDOWS_PRODUCT_NAME@\0"
      VALUE "ProductVersion", "@QMUD_WINDOWS_VERSION_DOTS@\0"
      VALUE "Comments", "@QMUD_WINDOWS_COMMENTS@\0"
      VALUE "LegalTrademarks", "Author: @QMUD_WINDOWS_AUTHOR_NAME@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
